{
  "name": "muba-backend",
  "version": "1.0.0",
  "description": "Backend for Sistema de Gestión para Instituciones de Salud",
  "main": "app.mjs",
  "type": "module",
  "scripts": {
    "start": "node startServer.mjs",
    "dev": "node startServer.mjs",
    "db:test:up": "docker-compose -f db_test/docker-compose.yml up -d",
    "db:test:down": "docker-compose -f db_test/docker-compose.yml down",
    "db:test:seed": "node db_test/seed.mjs",
    "db:test:setup": "npm run db:test:up && sleep 3 && npm run prisma:generate && npm run prisma:push && npm run db:test:seed",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:push": "npx prisma db push",
    "prisma:studio": "npx prisma studio",
    "prisma:seed": "node prisma/seed.mjs"
  },
  "keywords": [
    "healthcare",
    "management",
    "backend"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "pg": "^8.13.0",
    "pdfkit": "^0.17.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "prisma": "^7.4.1"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  }
}
