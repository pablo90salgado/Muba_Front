generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum HabitacionTipo {
  Individual
  Doble
  Triple
  Compartida
}

enum HabitacionEstado {
  Activa
  EnMantenimiento
  FueraDeServicio
}

enum CamaEstado {
  Disponible
  Ocupada
  EnLimpieza
  EnMantenimiento
  Reservada
}

enum ResidenteSexo {
  Masculino
  Femenino
  Otro
}

enum ResidenteEstado {
  Activo
  AusenciaTemporal
  Egresado
  Fallecido
}

enum ResponsablePagoIva {
  RespInscripto
  Monotributista
  ConsFinal
  Exento
}

enum FinanciadorTipo {
  OSNacional
  OSProvincial
  Prepaga
  Sindical
}

enum PlanEstado {
  Vigente
  Suspendido
  DadoDeBaja
}

enum ConvenioModalidad {
  ModuloFijo
  DiaCama
  Prestacion
  Capitado
}

enum DocumentoTipo {
  DNI
  CarnetOS
  Autorizacion
  PoderLegal
  Otro
}

enum AuditoriaAccion {
  CREATE
  READ
  UPDATE
  DELETE
}

enum InstitucionTipo {
  GERIATRICO
  CLINICA
  OTRO
}

enum PlanSaas {
  BASICO
  ESTANDAR
  PREMIUM
}

// ============================================
// MODELS - MVP (Phase 1)
// ============================================

model Institucion {
  id          String        @id @default(uuid())
  nombre      String        @db.VarChar(150)
  cuit        String        @unique @db.VarChar(13)
  tipo        InstitucionTipo
  direccion   String?       @db.VarChar(255)
  emailAdmin  String        @map("email_admin") @unique @db.VarChar(100)
  planSaas    PlanSaas      @map("plan_saas")
  activa      Boolean       @default(true)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relations
  edificios     Edificio[]
  residentes    Residente[]
  financiadores Financiador[]
  usuarios      Usuario[]

  @@map("institucion")
}

model Edificio {
  id            String   @id @default(uuid())
  institucionId String   @map("institucion_id")
  nombre        String   @db.VarChar(100)
  direccion     String?  @db.VarChar(255)
  descripcion   String?  @db.Text
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  institucion Institucion @relation(fields: [institucionId], references: [id])

  pisos Piso[]

  @@map("edificio")
}

model Piso {
  id          String  @id @default(uuid())
  edificioId  String  @map("edificio_id")
  nombre      String  @db.VarChar(50)
  orden       Int?
  activo      Boolean @default(true)

  edificio Edificio  @relation(fields: [edificioId], references: [id])
  sectores Sector[]

  @@map("piso")
}

model Sector {
  id        String  @id @default(uuid())
  pisoId    String  @map("piso_id")
  nombre    String  @db.VarChar(50)
  activo    Boolean @default(true)

  piso       Piso        @relation(fields: [pisoId], references: [id])
  habitaciones Habitacion[]

  @@map("sector")
}

model Habitacion {
  id               String         @id @default(uuid())
  sectorId         String         @map("sector_id")
  numero           String         @db.VarChar(20)
  tipo             HabitacionTipo
  amenities        Json?
  precioReferencial Decimal?      @db.Decimal(12, 2)
  estado           HabitacionEstado
  activo           Boolean        @default(true)

  sector Sector  @relation(fields: [sectorId], references: [id])
  camas  Cama[]

  @@map("habitacion")
}

model Cama {
  id           String    @id @default(uuid())
  habitacionId String    @map("habitacion_id")
  identificador String   @db.VarChar(20)
  estado       CamaEstado
  activo       Boolean   @default(true)

  habitacion      Habitacion       @relation(fields: [habitacionId], references: [id])
  asignacionesCama AsignacionCama[]

  @@map("cama")
}

model Residente {
  id                   String           @id @default(uuid())
  institucionId        String           @map("institucion_id")
  dni                  String           @db.VarChar(15)
  nombre               String           @db.VarChar(100)
  fechaNacimiento      DateTime         @map("fecha_nacimiento")
  sexo                 ResidenteSexo
  telefono             String?          @db.VarChar(30)
  email                String?          @db.VarChar(100)
  direccionProcedencia String?          @map("direccion_procedencia") @db.VarChar(255)
  fotoUrl              String?          @map("foto_url") @db.VarChar(500)
  estado               ResidenteEstado
  fechaIngreso         DateTime         @map("fecha_ingreso")
  fechaEgreso          DateTime?        @map("fecha_egreso")
  alergias             String?          @db.Text
  restriccionesAlimentarias String?      @map("restricciones_alimentarias") @db.Text
  observacionesMedicas String?          @map("observaciones_medicas") @db.Text
  medicoNombre         String?          @map("medico_nombre") @db.VarChar(100)
  medicoMatricula      String?          @map("medico_matricula") @db.VarChar(30)
  medicoEspecialidad   String?          @map("medico_especialidad") @db.VarChar(50)
  medicoTelefono       String?          @map("medico_telefono") @db.VarChar(30)
  medicoEmail          String?          @map("medico_email") @db.VarChar(100)
  eliminado            Boolean          @default(false)
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")

  institucion          Institucion      @relation(fields: [institucionId], references: [id])
  responsablePago       ResponsablePago?
  contactosEmergencia  ContactoEmergencia[]
  coberturas            CoberturaResidente[]
  documentos            Documento[]
  asignacionesCama      AsignacionCama[]
  historialEstados      HistorialEstadoResidente[]

  @@unique([institucionId, dni])
  @@map("residente")
}

model ResponsablePago {
  id                String              @id @default(uuid())
  residenteId       String              @unique @map("residente_id")
  nombre            String              @db.VarChar(100)
  relacion          String?             @db.VarChar(50)
  cuitCuil          String?             @map("cuit_cuil") @db.VarChar(13)
  condicionIva      ResponsablePagoIva? @map("condicion_iva")
  direccionFiscal   String?             @map("direccion_fiscal") @db.VarChar(255)
  tipoComprobante   String?             @map("tipo_comprobante")
  emailFacturacion  String?             @map("email_facturacion") @db.VarChar(100)
  telefono          String?             @db.VarChar(30)
  observaciones     String?             @db.Text

  residente Residente @relation(fields: [residenteId], references: [id])

  @@map("responsable_pago")
}

model ContactoEmergencia {
  id                  String   @id @default(uuid())
  residenteId         String   @map("residente_id")
  nombre              String   @db.VarChar(100)
  relacion            String   @db.VarChar(50)
  telefonoPrimario    String   @map("telefono_primario") @db.VarChar(30)
  telefonoSecundario  String?  @map("telefono_secundario") @db.VarChar(30)
  email               String?  @db.VarChar(100)
  esPrincipal         Boolean  @default(true) @map("es_principal")

  residente Residente @relation(fields: [residenteId], references: [id])

  @@map("contacto_emergencia")
}

model Financiador {
  id                    String           @id @default(uuid())
  institucionId         String           @map("institucion_id")
  nombre                String           @db.VarChar(150)
  cuit                  String           @db.VarChar(13)
  tipo                  FinanciadorTipo
  direccionFiscal       String?          @map("direccion_fiscal") @db.VarChar(255)
  emailLiquidaciones    String?          @map("email_liquidaciones") @db.VarChar(100)
  telefono              String?          @db.VarChar(30)
  personaContacto       String?          @map("persona_contacto") @db.VarChar(100)
  condicionesPago       String?          @map("condiciones_pago") @db.Text
  requisitosFacturacion String?          @map("requisitos_facturacion") @db.Text
  estado                String           @default("Activo")

  institucion Institucion @relation(fields: [institucionId], references: [id])

  planes          Plan[]
  convenios       Convenio[]
  coberturas      CoberturaResidente[]

  @@unique([institucionId, cuit])
  @@map("financiador")
}

model Plan {
  id                 String      @id @default(uuid())
  financiadorId      String      @map("financiador_id")
  nombre             String      @db.VarChar(100)
  coberturaDias      Int?        @map("cobertura_dias")
  serviciosIncluidos Json?       @map("servicios_incluidos")
  serviciosExcluidos Json?       @map("servicios_excluidos")
  coseguros          Json?
  auditoriasRequeridas String?   @map("auditorias_requeridas") @db.Text
  estado             PlanEstado

  financiador     Financiador        @relation(fields: [financiadorId], references: [id])
  convenios       Convenio[]
  coberturas      CoberturaResidente[]

  @@map("plan")
}

model Convenio {
  id           String           @id @default(uuid())
  financiadorId String         @map("financiador_id")
  planId       String?          @map("plan_id")
  servicio     String           @db.VarChar(100)
  modalidad    ConvenioModalidad
  valor        Decimal          @db.Decimal(12, 2)
  fechaDesde   DateTime         @map("fecha_desde")
  fechaHasta   DateTime?        @map("fecha_hasta")

  financiador Financiador @relation(fields: [financiadorId], references: [id])
  plan        Plan?       @relation(fields: [planId], references: [id])

  @@map("convenio")
}

model CoberturaResidente {
  id                String   @id @default(uuid())
  residenteId       String   @map("residente_id")
  financiadorId     String   @map("financiador_id")
  planId            String?  @map("plan_id")
  nroAfiliado       String   @map("nro_afiliado") @db.VarChar(50)
  fechaVigenciaDesde DateTime @map("fecha_vigencia_desde")
  fechaVigenciaHasta DateTime? @map("fecha_vigencia_hasta")
  activa            Boolean  @default(true)
  carnetUrl         String?  @map("carnet_url") @db.VarChar(500)

  residente   Residente   @relation(fields: [residenteId], references: [id])
  financiador Financiador @relation(fields: [financiadorId], references: [id])
  plan        Plan?       @relation(fields: [planId], references: [id])

  @@unique([residenteId, activa])
  @@map("cobertura_residente")
}

model AsignacionCama {
  id           String    @id @default(uuid())
  residenteId  String    @map("residente_id")
  camaId       String    @map("cama_id")
  fechaDesde   DateTime  @map("fecha_desde")
  fechaHasta   DateTime? @map("fecha_hasta")
  motivoCambio String?   @map("motivo_cambio") @db.Text
  usuarioId    String    @map("usuario_id")

  residente Residente @relation(fields: [residenteId], references: [id])
  cama     Cama      @relation(fields: [camaId], references: [id])
  usuario  Usuario   @relation(fields: [usuarioId], references: [id])

  @@map("asignacion_cama")
}

model HistorialEstadoResidente {
  id            String           @id @default(uuid())
  residenteId   String           @map("residente_id")
  estadoAnterior ResidenteEstado? @map("estado_anterior")
  estadoNuevo   ResidenteEstado   @map("estado_nuevo")
  fecha         DateTime          @default(now())
  motivo        String            @db.Text
  usuarioId     String            @map("usuario_id")

  residente Residente @relation(fields: [residenteId], references: [id])
  usuario   Usuario   @relation(fields: [usuarioId], references: [id])

  @@map("historial_estado_residente")
}

model Documento {
  id          String        @id @default(uuid())
  residenteId String        @map("residente_id")
  tipo        DocumentoTipo
  descripcion String?       @db.VarChar(255)
  archivoUrl  String        @map("archivo_url") @db.VarChar(500)
  fechaCarga  DateTime      @default(now()) @map("fecha_carga")

  residente Residente @relation(fields: [residenteId], references: [id])

  @@map("documento")
}

model Usuario {
  id               String    @id @default(uuid())
  institucionId    String    @map("institucion_id")
  email            String    @db.VarChar(100)
  passwordHash     String    @map("password_hash") @db.VarChar(255)
  nombre           String    @db.VarChar(100)
  rolId            String    @map("rol_id")
  activo           Boolean   @default(true)
  ultimoLogin      DateTime? @map("ultimo_login")
  intentosFallidos Int       @default(0) @map("intentos_fallidos")
  bloqueadoHasta   DateTime? @map("bloqueado_hasta")

  institucion           Institucion              @relation(fields: [institucionId], references: [id])
  rol                   Rol                      @relation(fields: [rolId], references: [id])
  asignacionesCama      AsignacionCama[]
  historialEstados      HistorialEstadoResidente[]
  auditorias            AuditoriaLog[]

  @@unique([institucionId, email])
  @@map("usuario")
}

model Rol {
  id          String  @id @default(uuid())
  nombre      String  @unique @db.VarChar(50)
  permisos    Json
  descripcion String? @db.Text

  usuarios Usuario[]

  @@map("rol")
}

// ============================================
// MODELS - Phase 2 (Prepared but not active in MVP)
// ============================================

model AuditoriaLog {
  id           String         @id @default(uuid())
  usuarioId    String         @map("usuario_id")
  accion       AuditoriaAccion
  entidad      String         @db.VarChar(50)
  entidadId    String         @map("entidad_id")
  datosAnteriores Json?       @map("datos_anteriores")
  datosNuevos Json?          @map("datos_nuevos")
  ipAddress    String?        @map("ip_address") @db.VarChar(45)
  userAgent    String?        @map("user_agent") @db.VarChar(255)
  timestamp    DateTime       @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("audit_log")
}
